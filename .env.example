NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — Project ID (for type generation)
SUPABASE_PROJECT_ID=

# Supabase — CLI access token (for migrations and type generation)
SUPABASE_ACCESS_TOKEN=
